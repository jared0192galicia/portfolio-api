{
  "name": "nafa-api",
  "version": "1.0.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --hot src/index.ts",
    "lint": "bunx oxlint@latest --fix --ignore-pattern 'node_modules/**'",
    "migrate": "bunx prisma migrate dev",
    "migrate:deploy": "bunx prisma migrate deploy",
    "migrate:reset": "bunx prisma migrate reset",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate"
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "@hono/zod-openapi": "^1.2.4",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@scalar/hono-api-reference": "^0.10.6",
    "chalk": "^5.6.2",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "prisma": "^7.7.0",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/pg": "^8.20.0"
  },
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
