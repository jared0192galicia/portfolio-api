// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("POSTGRE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  username     String   @unique @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash")
  phone        String?  @db.VarChar(20)
  role         String   @default("user") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  
  // Relations
  
  @@map("users")
}

model visit {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  
  // Información de red
  ip                String   
  network           String?
  version           String? 
  asn               String?
  org               String?

  // Ubicación específica
  city              String?
  region            String?
  regionCode        String?  @map("region_code")
  postal            String?
  latitude          Float?
  longitude         Float?
  timezone          String?
  utcOffset         String?  @map("utc_offset")

  // Datos de país
  country           String?
  countryName       String?  @map("country_name")
  countryCode       String?  @map("country_code")
  countryCodeIso3   String?  @map("country_code_iso3")
  countryCapital    String?  @map("country_capital")
  countryTld        String?  @map("country_tld")
  continentCode     String?  @map("continent_code")
  inEu              Boolean  @default(false) @map("in_eu")

  // Datos económicos/sociales
  countryCallingCode String? @map("country_calling_code")
  currency          String?
  currencyName      String?  @map("currency_name")
  languages         String?  // Almacenado como string "es-MX,en-US"
  countryArea       Float?   @map("country_area")
  countryPopulation BigInt?  @map("country_population")

  @@index([countryCode])
  @@index([city])
}